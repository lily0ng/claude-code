{
  "name": "claude-code",
  "version": "2.1.108",
  "description": "vxrt code — fork of Anthropic Claude Code, configured for Ollama and OpenRouter",
  "private": true,
  "scripts": {
    "start": "ANTHROPIC_AUTH_TOKEN=ollama ANTHROPIC_BASE_URL=http://localhost:11434 claude",
    "dev": "ANTHROPIC_AUTH_TOKEN=ollama ANTHROPIC_BASE_URL=http://localhost:11434 claude --model llama3.2",
    "openrouter": "claude",
    "ollama:serve": "ollama serve",
    "ollama:pull": "ollama pull llama3.2",
    "ollama:list": "ollama list",
    "setup": "ollama pull llama3.2 && echo 'Ready. Run: npm run dev'"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
